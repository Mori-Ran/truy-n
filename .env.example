GOOGLE_DRIVE_SYSTEM_FOLDER_ID=your-system-folder-id

# Account 0
GOOGLE_OAUTH_CLIENT_ID=your_client_id
GOOGLE_OAUTH_CLIENT_SECRET=your_client_secret
# Optional if you want to store the refresh token as an env var
GOOGLE_OAUTH_REFRESH_TOKEN=your_google_oauth_refresh_token
# Optional local file path to persist refresh token
GOOGLE_OAUTH_TOKEN_FILE=instance/google_drive_oauth.json

# Google Drive folder IDs for uploads
# Supported aliases (any one is enough):
# GOOGLE_DRIVE_COVER-IMAGES_FOLDER_ID, GOOGLE_DRIVE_COVER_IMAGES_FOLDER_ID,
# GOOGLE_DRIVE_COVER_FOLDER_ID, GOOGLE_DRIVE_COVER_FOLDER
GOOGLE_DRIVE_COVER-IMAGES_FOLDER_ID=your_posters_folder_id
# Supported aliases (any one is enough):
# GOOGLE_DRIVE_NOVEL-CONTENT_FOLDER_ID, GOOGLE_DRIVE_NOVEL_CONTENT_FOLDER_ID,
# GOOGLE_DRIVE_NOVEL_FOLDER_ID, GOOGLE_DRIVE_NOVEL_FOLDER
GOOGLE_DRIVE_NOVEL-CONTENT_FOLDER_ID=your_videos_folder_id

# Flask settings
SECRET_KEY=replace-with-a-secret
SITE_NAME=Novel-BL
ADMIN_PASSWORD=3,141592653589793
DATABASE_URL=sqlite:///instance/movie_manager.sqlite3
